{
  "name": "aegis-flow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "node --experimental-strip-types src/index.ts",
    "scenario": "node --experimental-strip-types src/scenarios.ts",
    "dashboard": "node --experimental-strip-types src/dashboard.ts",
    "dashboard:quiet": "node --experimental-strip-types src/dashboard.ts --quiet"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
